{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Cinch",
	"version": "0.1.0",
	"identifier": "me.jinmu.cinch",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Cinch",
				"width": 1080,
				"height": 640,
				"visible": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": [
			"dmg",
			"app"
		],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"macOS": {
			"minimumSystemVersion": "10.15"
		}
	},
	"plugins": {
		"deep-link": {
			"desktop": {
				"schemes": ["cinch"]
			}
		},
		"updater": {
			"endpoints": [
				"https://github.com/jinmu/cinch/releases/latest/download/latest.json"
			],
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQwRDg5NzMxNEMwQkY0QUMKUldTczlBdE1NWmZZME41NnE2akU2L3RHaFM5Y1NPM0prSkpqK2lWM3JqQXRtdy9KTFNxUjJOcFIK"
		}
	}
}
